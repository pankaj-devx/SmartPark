# ── Server environment variables (server/.env) ──────────────────────────────
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/smartpark
SKIP_DB_CONNECT=true
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173,http://127.0.0.1:5173
AUTH_DEBUG=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=smartpark/parkings
RAZORPAY_KEY_ID=your_key
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
ALLOW_TEST_PAYMENT=true
TEST_COUPON_CODE=FREE100
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# ── Client environment variables (client/.env) ───────────────────────────────
# Vite only reads .env files from the client/ directory.
# All browser-exposed variables must be prefixed with VITE_.
VITE_API_BASE_URL=http://localhost:5000/api
VITE_DEBUG_API=false
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
# Routing uses the OSRM public demo API (no key required).
# If you self-host OSRM or switch to OpenRouteService, set this:
# VITE_OSRM_BASE_URL=https://router.project-osrm.org/route/v1/driving
